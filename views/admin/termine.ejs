<%- include('head') %>
<h1>Termine verwalten</h1>
<h2 class="admin-sub">Neuer Termin</h2>
<form method="post" action="/admin/termine/neu" class="admin-form termin-row">
  <input type="text" name="datum" placeholder="z. B. Dienstag, 14. Juli 2026" required>
  <input type="text" name="titel" placeholder="Titel (z. B. Platzkonzert)" required>
  <input type="text" name="ort" placeholder="Ort">
  <input type="text" name="hinweis" placeholder="Hinweis (optional)">
  <button class="btn btn-gold">+ Hinzufügen</button>
</form>
<h2 class="admin-sub">Bestehende Termine</h2>
<% events.forEach(e => { %>
  <form method="post" action="/admin/termine/<%= e.id %>" class="admin-form termin-row">
    <input type="text" name="datum" value="<%= e.datum %>">
    <input type="text" name="titel" value="<%= e.titel %>">
    <input type="text" name="ort" value="<%= e.ort %>">
    <input type="text" name="hinweis" value="<%= e.hinweis %>">
    <input type="number" name="sort" value="<%= e.sort %>" title="Reihenfolge" style="width:70px">
    <button class="btn-small">Speichern</button>
    <button class="btn-small danger" formaction="/admin/termine/<%= e.id %>/loeschen" onclick="return confirm('Termin löschen?')">Löschen</button>
  </form>
<% }) %>
<%- include('foot') %>
