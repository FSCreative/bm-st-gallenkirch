<%- include('partials/header') %>
<% const gp = resolveImage('2481867531'); %>
<% if (gp) { %>
<section class="register-hero">
  <img src="<%= gp %>" alt="Vorstand der Bürgermusik St. Gallenkirch">
  <div class="register-hero-overlay"></div>
  <div class="register-hero-text container">
    <p>Die Vereinsleitung</p>
    <h1>Vorstand</h1>
  </div>
</section>
<% } else { %>
<section class="page-head slim">
  <div class="container">
    <p class="page-head-kicker">Die Vereinsleitung</p>
    <h1>Vorstand</h1>
  </div>
</section>
<% } %>
<section class="section">
  <div class="container">
    <div class="person-grid">
      <% vorstand.forEach(v => { const img = resolveImage(v.image); %>
        <div class="person-card reveal">
          <div class="person-img"><% if (img) { %><img src="<%= img %>" alt="<%= v.name %>" loading="lazy"><% } else { %><div class="person-ph">♪</div><% } %></div>
          <div class="person-body">
            <span class="person-role"><%= v.role %></span>
            <h3><%= v.name %></h3>
            <ul class="person-details">
              <% v.details.forEach(d => { %><li><%= d %></li><% }) %>
            </ul>
            <% if (v.extra) { %><p class="person-extra"><%= v.extra %></p><% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
